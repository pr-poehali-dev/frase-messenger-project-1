{
  "tests": [
    {
      "name": "Login with existing user",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "test_frase_001@example.com", "password": "secret123"},
      "expectedStatus": 200
    },
    {
      "name": "Login with wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "test_frase_001@example.com", "password": "wrongpass"},
      "expectedStatus": 401
    },
    {
      "name": "Me without token",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401
    },
    {
      "name": "Unknown action returns 404",
      "method": "GET",
      "path": "/",
      "expectedStatus": 404
    }
  ]
}